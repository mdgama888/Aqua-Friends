{
  "expo": {
    "name": "Aqua Friend",
    "slug": "aqua-friend",
    "version": "1.0.0",  // 👈 ДОБАВЛЕНО
    "orientation": "portrait",
    "icon": "./assets/icon.png",  // 👈 ДОБАВЛЕНО
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#001524"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mmdms.aquaoffline"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#001524"  // 👈 ДОБАВЛЕНО
      },
      "package": "com.mmdms.aquaoffline",
      "versionCode": 1  // 👈 ДОБАВЛЕНО
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1924cc9d-9731-4ddc-84d7-c8a24dbcf0e5"
      }
    },
    "plugins": [
      "expo-sharing",
      "expo-barcode-scanner",
      [
        "expo-image-picker",  // 👈 ДОБАВЛЕНО
        {
          "photosPermission": "Приложению нужен доступ к фото, чтобы отправлять их в чат."
        }
      ]
    ]
  }
}
